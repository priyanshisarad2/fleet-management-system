# Bucket needs to be created in advance
# This will store the terraform state for the project

bucket  = "fleetman-tf-state"
key     = "prod/terraform.tfstate"
region  = "us-east-1"
encrypt = true

# Bucket Configurations:
# - Versioning: Enabled
# - ACL: Disabled
# - Public Access: Disabled
# - Set Lifecycle Rules to reduce cost